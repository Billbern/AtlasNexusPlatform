###############################################################################
# Atlas Nexus - LiteLLM Configuration
###############################################################################
#
# Copy this file to .env and edit:
#
#   cp .env.example .env
#
# The .env file is gitignored, so your secrets stay local.
###############################################################################
 
# ---------------------------------------------------------------------------
# Container
# ---------------------------------------------------------------------------
 
CONTAINER_NAME=atlas-nexus-litellm
IMAGE=litellm/litellm:main
 
# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------
 
HOST=0.0.0.0
PORT=4000
 
# ---------------------------------------------------------------------------
# Model
# ---------------------------------------------------------------------------
 
LITELLM_MODEL=Qwen/Qwen3-8B
 
# ---------------------------------------------------------------------------
# vLLM Backend
# ---------------------------------------------------------------------------
# Set VLLM_BASE_URL to the internal Docker network address of your vLLM service
# This should be http://vllm:8000 by default if using Docker's internal network
LITELLM_VLLM_BASE_URL=http://vllm:8000
 
# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Set LITELLM_LOG_LEVEL to control verbosity
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LITELLM_LOG_LEVEL=INFO