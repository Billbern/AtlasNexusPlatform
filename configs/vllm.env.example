###############################################################################
# Atlas Nexus - vLLM Configuration
###############################################################################
#
# Copy this file to .env and edit:
#
#   cp .env.example .env
#
# The .env file is gitignored, so your secrets stay local.
###############################################################################

# ---------------------------------------------------------------------------
# Container
# ---------------------------------------------------------------------------

CONTAINER_NAME=atlas-nexus-vllm
IMAGE=vllm/vllm-openai:latest

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------

HOST=0.0.0.0
PORT=8000

# ---------------------------------------------------------------------------
# Model
# ---------------------------------------------------------------------------

MODEL=Qwen/Qwen3-8B

# ---------------------------------------------------------------------------
# Hugging Face
# ---------------------------------------------------------------------------
# Set HF_TOKEN if you need to download gated models (e.g. Llama, Mistral).
# Leave empty for public models.

HF_TOKEN=

# ---------------------------------------------------------------------------
# vLLM
# ---------------------------------------------------------------------------

DTYPE=auto
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=8192
TRUST_REMOTE_CODE=true

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

LOG_LEVEL=INFO